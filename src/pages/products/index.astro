---
// products/index.astro
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';

const products = [
  {
    title: "Flawless 錯題救星",
    subtitle: "AI 智能理科間隔重複複習系統",
    description: "隨手拍照免抄題，AI 自動將題目轉為精美 LaTeX 公式。結合間隔重複記憶法（SRS），動態生成具備計算陷阱的相似類題，戳破學習盲點，比真人助教更懂你！",
    tag: "AI 智能 & Web",
    tagColor: "bg-brand-mint/15 text-emerald-700",
    link: "/products/flawless",
    imageSrc: "/images/flawless/Screenshot 2026-06-23 100739.png",
    slogan: "別在同一個坑裡摔倒兩次！"
  },
  {
    title: "YomiYomi 讀讀日文新聞",
    subtitle: "AI 驅動的日文分級閱讀與句法分析器",
    description: "每日抓取日本時事新聞，由 AI 自動改寫為 N5/N3/N1 分級文章。獨創彩色語意結構標記、敬常體一鍵切換、智慧假名拼音顯示與一鍵動態動詞還原，讀出日文直覺！",
    tag: "AI 學習 & iOS / Android",
    tagColor: "bg-brand-yellow/20 text-amber-700",
    link: "/products/yomiyomi",
    imageSrc: "/images/yomiyomi/YomiYomi-1.png",
    slogan: "讀懂日本，不止讀懂新聞。"
  },
  {
    title: "皮克敏飾品地圖",
    subtitle: "Pikmin Bloom Decor Map 社群純點地圖",
    description: "專為 Pikmin Bloom 玩家設計的點位回報與查詢系統。精準篩選 43 種飾品點位，提供 100% 命中的社群認證「純點」，支援大範圍 50 公里搜尋與離線地理判定。",
    tag: "社群互助 & Android",
    tagColor: "bg-brand-orange/15 text-rose-700",
    link: "/products/pikmin-map",
    imageSrc: "/images/pikmin/Screenshot_tw_1.png",
    slogan: "雷達不再踩雷，百分百「純點」一擊必中！"
  }
];
---

<Layout 
  title="工作室產品總覽" 
  description="川朵數位精緻軟體工具列表：Flawless 理科錯題系統、YomiYomi 日文學習 App、皮克敏飾品地圖。以遊戲化、有溫度的介面解決您的真實生活痛點。"
  keywords="Flawless, YomiYomi, 皮克敏飾品地圖, 川朵數位, App產品列表, 線上學習工具"
>
  <!-- Hero Section -->
  <section class="relative bg-slate-900 text-white overflow-hidden py-16">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_30%,rgba(86,227,159,0.1),transparent_40%)]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_80%,rgba(247,208,112,0.08),transparent_40%)]"></div>
    
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight">
        探索 <span class="bg-gradient-to-r from-brand-mint via-brand-yellow to-brand-orange bg-clip-text text-transparent">川朵數位</span> 的創意工具
      </h1>
      <p class="mt-4 text-lg text-slate-300 max-w-2xl mx-auto leading-relaxed">
        我們不只打造好用的軟體，更融入「輕遊戲化」與「人性化體驗」，讓學習與生活工具變得有溫度、有趣且無壓力。
      </p>
    </div>
  </section>

  <!-- Product Grid -->
  <section class="py-16 container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {products.map(p => (
        <ProductCard {...p} />
      ))}
    </div>
  </section>

  <!-- Sponsoring & Business Model Overview -->
  <section class="py-16 bg-slate-100/50 border-t border-b border-slate-200/60">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <h2 class="text-3xl font-bold text-slate-900">服務方案與商業變現機制</h2>
        <p class="mt-3 text-slate-600">
          為了確保工作室能長期穩定營運，平衡網路服務與 AI API 等伺服器成本，我們的產品採用合理的「免費版＋加值訂閱」或「廣告機制」模式：
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <!-- Flawless Pricing Card -->
        <div class="bg-white rounded-3xl p-6 border border-slate-200/60 shadow-sm flex flex-col justify-between">
          <div>
            <span class="inline-flex items-center rounded-full bg-emerald-50 px-2.5 py-0.5 text-xs font-semibold text-emerald-700">
              訂閱制 (Freemium)
            </span>
            <h3 class="text-xl font-bold text-slate-900 mt-3">Flawless 錯題救星</h3>
            <p class="text-xs text-slate-400 mt-1">高中理科 AI 智能複習系統</p>
            <hr class="my-4 border-slate-100" />
            <ul class="space-y-2 text-xs text-slate-600">
              <li class="flex items-start">
                <span class="text-emerald-500 mr-2">✓</span> <strong>免費版</strong>：每日上傳 5 題 / 基本分類管理
              </li>
              <li class="flex items-start">
                <span class="text-emerald-500 mr-2">✓</span> <strong>Premium 訂閱</strong>：NT$ 90/月 ($2.99 USD)
              </li>
              <li class="flex items-start pl-4 text-slate-500">
                • 解鎖無限上傳 & AI 錯題解析<br />
                • AI 相似類題推薦 & 考前複習 PDF 生成
              </li>
            </ul>
          </div>
          <div class="mt-6">
            <a href="/products/flawless" class="block w-full text-center rounded-xl bg-slate-900 py-2.5 text-xs font-bold text-white hover:bg-brand-mint hover:text-slate-900 transition-colors">
              查看 Flawless 詳情
            </a>
          </div>
        </div>

        <!-- YomiYomi Pricing Card -->
        <div class="bg-white rounded-3xl p-6 border-2 border-brand-yellow shadow-md flex flex-col justify-between relative">
          <div class="absolute -top-3 right-6 bg-brand-yellow text-slate-900 font-bold text-[10px] px-2 py-0.5 rounded-full uppercase tracking-wider">
            熱門推薦
          </div>
          <div>
            <span class="inline-flex items-center rounded-full bg-amber-50 px-2.5 py-0.5 text-xs font-semibold text-amber-700">
              訂閱制 + 廣告
            </span>
            <h3 class="text-xl font-bold text-slate-900 mt-3">YomiYomi 日文學習</h3>
            <p class="text-xs text-slate-400 mt-1">AI 驅動分級新聞閱讀器</p>
            <hr class="my-4 border-slate-100" />
            <ul class="space-y-2 text-xs text-slate-600">
              <li class="flex items-start">
                <span class="text-amber-500 mr-2">✓</span> <strong>免費版</strong>：每日限讀 2 篇 / 含廣告 / 單字本上限 20 組
              </li>
              <li class="flex items-start">
                <span class="text-amber-500 mr-2">✓</span> <strong>VIP 訂閱</strong>：NT$ 60/月 ($1.99 USD / NT$90)
              </li>
              <li class="flex items-start pl-4 text-slate-500">
                • 100% 無廣告純淨體驗 & 無限閱讀<br />
                • 語音朗讀 & 雲端同步無限生字庫<br />
                • 指定關鍵字即時 AI 生成新聞
              </li>
            </ul>
          </div>
          <div class="mt-6">
            <a href="/products/yomiyomi" class="block w-full text-center rounded-xl bg-brand-yellow py-2.5 text-xs font-bold text-slate-900 hover:bg-slate-900 hover:text-white transition-colors">
              查看 YomiYomi 詳情
            </a>
          </div>
        </div>

        <!-- Pikmin Map Pricing Card -->
        <div class="bg-white rounded-3xl p-6 border border-slate-200/60 shadow-sm flex flex-col justify-between">
          <div>
            <span class="inline-flex items-center rounded-full bg-rose-50 px-2.5 py-0.5 text-xs font-semibold text-rose-700">
              廣告變現 + 內購
            </span>
            <h3 class="text-xl font-bold text-slate-900 mt-3">皮克敏飾品地圖</h3>
            <p class="text-xs text-slate-400 mt-1">Pikmin Bloom Decor Map 導航工具</p>
            <hr class="my-4 border-slate-100" />
            <ul class="space-y-2 text-xs text-slate-600">
              <li class="flex items-start">
                <span class="text-rose-500 mr-2">✓</span> <strong>免費版</strong>：全功能解鎖 / 常駐 AdMob 橫幅廣告
              </li>
              <li class="flex items-start">
                <span class="text-rose-500 mr-2">✓</span> <strong>一次性去廣告內購</strong>：NT$ 30 ($0.99 USD)
              </li>
              <li class="flex items-start pl-4 text-slate-500">
                • 解鎖 100% 乾淨無廣告地圖<br />
                • 解鎖專屬飾品圖標標記 / 小額贊助開發者
              </li>
            </ul>
          </div>
          <div class="mt-6">
            <a href="/products/pikmin-map" class="block w-full text-center rounded-xl bg-slate-900 py-2.5 text-xs font-bold text-white hover:bg-brand-mint hover:text-slate-900 transition-colors">
              查看皮克敏地圖詳情
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
