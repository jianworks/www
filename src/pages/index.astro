---
// index.astro
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';

const featuredProducts = [
  {
    title: "Flawless 錯題救星",
    subtitle: "AI 智能理科間隔重複複習系統",
    description: "手機拍下錯題上傳，AI 自動將題目轉為精美排版的 LaTeX 公式。結合間隔重複記憶法（SRS），動態生成具備計算陷阱的相似類題，戳破學習盲點，比物理化學助教更懂你！",
    tag: "AI 智能 & Web",
    tagColor: "bg-brand-mint/15 text-emerald-700",
    link: "/products/flawless",
    imageSrc: "/images/flawless/Screenshot 2026-06-23 100739.png",
    slogan: "別在同一個坑裡摔倒兩次！"
  },
  {
    title: "YomiYomi 讀讀日文新聞",
    subtitle: "AI 驅動的日文分級閱讀與句法分析器",
    description: "每日日本時事新聞 N5/N3/N1 分級改寫。獨創彩色語意結構標記、敬常體一鍵切換、智慧假名注音顯示與一鍵動態動詞還原。告別死記硬背，輕鬆讀出日文直覺！",
    tag: "AI 學習 & iOS / Android",
    tagColor: "bg-brand-yellow/20 text-amber-700",
    link: "/products/yomiyomi",
    imageSrc: "/images/yomiyomi/YomiYomi-1.png",
    slogan: "讀懂日本，不止讀懂新聞。"
  },
  {
    title: "皮克敏飾品地圖",
    subtitle: "Pikmin Bloom Decor Map 社群純點地圖",
    description: "玩家必備的點位回報與查詢地圖。精準篩選 43 種飾品，標記 100% 命中的社群認證「純點」，支持大範圍 50 公里搜尋與離線地理判定，出遊採集最佳導航伴侶。",
    tag: "社群互助 & Android",
    tagColor: "bg-brand-orange/15 text-rose-700",
    link: "/products/pikmin-map",
    imageSrc: "/images/pikmin/Screenshot_tw_1.png",
    slogan: "雷達不再踩雷，百分百「純點」一擊必中！"
  }
];
---

<Layout 
  title="川朵數位官方網站 | Triodose Digital Studio" 
  description="川朵數位工作室專注於打造「輕鬆、遊戲化、有溫度」的行動學習與生活工具，包含 Flawless 錯題系統、YomiYomi 日文學習 App、皮克敏飾品地圖。"
  keywords="川朵數位, Triodose Digital, Flawless, YomiYomi, 皮克敏飾品地圖, App開發, 獨立開發工作室"
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden py-24 md:py-32">
    <!-- Curved gradients representing Triodose brand colors -->
    <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_20%_20%,rgba(86,227,159,0.15),transparent_50%)]"></div>
    <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_80%_80%,rgba(247,208,112,0.12),transparent_50%)]"></div>
    <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_50%_50%,rgba(242,140,110,0.06),transparent_60%)]"></div>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-4xl mx-auto space-y-8">
        <!-- Badge -->
        <div class="inline-flex items-center gap-1.5 rounded-full bg-slate-900 px-3.5 py-1.5 text-xs font-semibold text-white shadow-sm">
          <span class="flex h-2 w-2 rounded-full bg-brand-mint animate-pulse"></span>
          川朵數位工作室 / Triodose Studio
        </div>

        <!-- Heading -->
        <h1 class="text-4xl sm:text-6xl font-extrabold tracking-tight text-slate-900 leading-tight">
          我們用 AI 與創意，<br />
          打造 <span class="bg-gradient-to-r from-brand-mint via-brand-yellow to-brand-orange bg-clip-text text-transparent">有溫度的數位體驗</span>
        </h1>

        <!-- Subtitle -->
        <p class="text-base sm:text-lg text-slate-500 max-w-2xl mx-auto leading-relaxed">
          川朵數位專注於為大眾與學生提供「輕鬆、遊戲化、有溫度」的行動學習與生活工具。我們拒絕冰冷、死板的軟體，致力於透過貼心的 UI 與實用的功能解決真實生活痛點。
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-wrap items-center justify-center gap-4 pt-4">
          <a 
            href="/products" 
            class="inline-flex items-center justify-center rounded-full bg-slate-900 px-6 py-3 text-sm font-bold text-white shadow-md transition-all duration-300 hover:bg-brand-mint hover:text-slate-900 hover:scale-105"
          >
            探索旗下產品
          </a>
          <a 
            href="mailto:cs.jian@triodose.com" 
            class="inline-flex items-center justify-center rounded-full border border-slate-350 bg-white px-6 py-3 text-sm font-semibold text-slate-700 shadow-sm transition-all hover:bg-slate-50"
          >
            聯絡我們
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Brand Concept Section -->
  <section class="py-20 bg-white border-t border-b border-slate-100">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <!-- Brand logo story (Left) -->
        <div class="lg:col-span-5 flex flex-col items-center justify-center space-y-6">
          <div class="relative p-6 bg-slate-50 rounded-3xl border border-slate-100 shadow-inner flex items-center justify-center w-72 aspect-square">
            <img src="/images/logo.png" alt="川朵數位 Logo" class="w-full h-auto object-contain max-h-56" />
          </div>
          <div class="text-center">
            <h3 class="font-bold text-slate-800 text-base">【 Logo 設計概念：創意幾何與微笑笑臉 】</h3>
            <p class="text-xs text-slate-400 mt-2 max-w-xs leading-relaxed">
              左側三條傾斜線條象徵「川」── 知識與資訊的涓滴成川、川流不息；右側自然轉化為微笑的小雲朵，代表「朵」與雲端服務，傳遞親和與溫暖。
            </p>
          </div>
        </div>

        <!-- Pillars (Right) -->
        <div class="lg:col-span-7 space-y-8">
          <div>
            <h2 class="text-3xl font-bold text-slate-900 tracking-tight">我們的三大核心價值</h2>
            <p class="text-slate-500 text-sm mt-2 leading-relaxed">
              不同於一般過度冰冷的效率軟體，我們相信工具也可以擁有靈魂：
            </p>
          </div>

          <div class="space-y-6">
            <!-- Pillar 1 -->
            <div class="flex gap-4">
              <div class="flex-shrink-0 h-10 w-10 rounded-full bg-brand-mint/10 flex items-center justify-center text-brand-mint text-base font-bold">
                🎮
              </div>
              <div>
                <h3 class="font-bold text-slate-900 text-sm">輕遊戲化體驗 (Gamified Learning)</h3>
                <p class="text-xs text-slate-500 mt-1 leading-relaxed">
                  將學習與採集地圖融入投票、對照、答題反思與排程，讓持之以恆變得自然且毫無負擔。
                </p>
              </div>
            </div>

            <!-- Pillar 2 -->
            <div class="flex gap-4">
              <div class="flex-shrink-0 h-10 w-10 rounded-full bg-brand-yellow/20 flex items-center justify-center text-brand-yellow text-base font-bold">
                🧸
              </div>
              <div>
                <h3 class="font-bold text-slate-900 text-sm">有人性的設計 (Human-centric Design)</h3>
                <p class="text-xs text-slate-500 mt-1 leading-relaxed">
                  使用溫潤明亮的配色，輕透的毛玻璃視覺，給予眼睛無負擔的溫暖閱讀介面與流暢動畫。
                </p>
              </div>
            </div>

            <!-- Pillar 3 -->
            <div class="flex gap-4">
              <div class="flex-shrink-0 h-10 w-10 rounded-full bg-brand-orange/15 flex items-center justify-center text-brand-orange text-base font-bold">
                ⚡
              </div>
              <div>
                <h3 class="font-bold text-slate-900 text-sm">AI 智慧自適應 (AI-Powered Engines)</h3>
                <p class="text-xs text-slate-500 mt-1 leading-relaxed">
                  利用最尖端的 Gemini 引擎，實現分級日文改寫與錯題類題生成，擺脫死背，學會融會貫通。
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Featured Products Grid -->
  <section class="py-20 bg-slate-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <h2 class="text-3xl font-bold text-slate-900 tracking-tight">精選產品展示</h2>
        <p class="mt-3 text-slate-500 text-sm leading-relaxed">
          針對大眾與學生群眾的不同需求，工作室目前推出三款核心工具，點擊可查看詳細規格與截圖。
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {featuredProducts.map(p => (
          <ProductCard {...p} />
        ))}
      </div>
    </div>
  </section>


  <!-- Studio Slogan Banner -->
  <section class="py-20 bg-gradient-to-r from-brand-mint/10 via-brand-yellow/10 to-brand-orange/10 text-slate-900 border-t border-slate-100">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center max-w-3xl space-y-6">
      <h2 class="text-2xl sm:text-3xl font-extrabold tracking-tight">
        「涓滴成川，自在如雲」
      </h2>
      <p class="text-slate-500 text-xs leading-relaxed max-w-xl mx-auto">
        在學習與生活探索的道路上，川朵數位與您攜手同行，將涓滴成川的點滴累積，轉化為如雲般的自在與成長。
      </p>
    </div>
  </section>
</Layout>
