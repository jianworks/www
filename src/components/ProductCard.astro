---
// ProductCard.astro
interface Props {
  title: string;
  subtitle: string;
  description: string;
  tag: string;
  tagColor: string; // e.g. "bg-brand-mint text-slate-900"
  link: string;
  imageSrc: string;
  slogan: string;
}

const { title, subtitle, description, tag, tagColor, link, imageSrc, slogan } = Astro.props;
---

<a href={link} class="group relative flex flex-col overflow-hidden rounded-3xl bg-white border border-slate-100 shadow-sm transition-all duration-500 hover:-translate-y-2 hover:shadow-xl">
  <!-- Top decorative color block -->
  <div class="h-2 w-full bg-gradient-to-r from-brand-mint via-brand-yellow to-brand-orange opacity-80 group-hover:opacity-100 transition-opacity"></div>
  
  <!-- Image Container -->
  <div class="relative overflow-hidden aspect-video bg-slate-100 flex items-center justify-center">
    <img 
      src={imageSrc} 
      alt={title} 
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
      <span class="text-white text-xs font-semibold tracking-wide italic">{slogan}</span>
    </div>
  </div>

  <!-- Content -->
  <div class="flex flex-col flex-grow p-6">
    <div class="flex items-center justify-between mb-2">
      <span class={`inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold ${tagColor}`}>
        {tag}
      </span>
    </div>
    
    <h3 class="text-xl font-bold text-slate-900 group-hover:text-brand-orange transition-colors">
      {title}
    </h3>
    <p class="text-xs text-slate-400 mt-1 font-medium">{subtitle}</p>
    
    <p class="text-sm text-slate-500 mt-3 leading-relaxed flex-grow">
      {description}
    </p>
  </div>
</a>
