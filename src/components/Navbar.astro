---
// Navbar.astro
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/' || currentPath === '/index.html';
const isFlawless = currentPath.startsWith('/products/flawless');
const isProducts = currentPath === '/products' || currentPath === '/products/' || currentPath.startsWith('/products/yomiyomi') || currentPath.startsWith('/products/pikmin-map');
const isPrivacy = currentPath.startsWith('/privacy');
---

<header class="sticky top-0 z-50 w-full transition-all duration-300 border-b border-slate-100 bg-white/80 backdrop-blur-md">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <div class="flex-shrink-0">
        <a href="/" class="flex items-center gap-2 group">
          <img src="/images/logo.png" alt="Triodose Digital" class="h-8 w-auto object-contain flex-shrink-0 transition-transform duration-300 group-hover:scale-105" style="height: 32px; width: auto;" />
          <span class="sr-only">川朵數位 (Triodose Digital)</span>
        </a>
      </div>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex space-x-8">
        <a 
          href="/" 
          class={`text-sm font-medium transition-colors hover:text-brand-mint ${isHome ? 'text-slate-900 border-b-2 border-brand-mint pb-1' : 'text-slate-500'}`}
        >
          首頁
        </a>
        <a 
          href="/products/flawless" 
          class={`text-sm font-medium transition-colors hover:text-brand-mint ${isFlawless ? 'text-slate-900 border-b-2 border-brand-mint pb-1' : 'text-slate-500'}`}
        >
          Flawless 錯題救星
        </a>
        <a 
          href="/products" 
          class={`text-sm font-medium transition-colors hover:text-brand-mint ${isProducts ? 'text-slate-900 border-b-2 border-brand-mint pb-1' : 'text-slate-500'}`}
        >
          精選 App
        </a>
        <a 
          href="/privacy" 
          class={`text-sm font-medium transition-colors hover:text-brand-mint ${isPrivacy ? 'text-slate-900 border-b-2 border-brand-mint pb-1' : 'text-slate-500'}`}
        >
          隱私權政策
        </a>
      </nav>

      <!-- Desktop Call to Action -->
      <div class="hidden md:flex items-center">
        <a 
          href="/products" 
          class="inline-flex items-center justify-center rounded-full bg-slate-900 px-4 py-2 text-xs font-semibold text-white shadow-sm transition-all duration-300 hover:bg-brand-mint hover:text-slate-900 hover:shadow-md"
        >
          探索產品
        </a>
      </div>

      <!-- Mobile menu button -->
      <div class="flex md:hidden">
        <button 
          type="button" 
          id="mobile-menu-button"
          class="inline-flex items-center justify-center rounded-md p-2 text-slate-400 hover:bg-slate-100 hover:text-slate-500 focus:outline-none"
          aria-controls="mobile-menu"
          aria-expanded="false"
        >
          <span class="sr-only">打開選單</span>
          <!-- Menu Icon -->
          <svg class="h-6 w-6" id="menu-icon-open" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
          <!-- Close Icon -->
          <svg class="hidden h-6 w-6" id="menu-icon-close" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div class="hidden md:hidden" id="mobile-menu">
    <div class="space-y-1 px-4 pb-4 pt-2 border-t border-slate-100 bg-white">
      <a 
        href="/" 
        class={`block rounded-md px-3 py-2 text-base font-medium ${isHome ? 'bg-slate-50 text-slate-950 font-semibold' : 'text-slate-600 hover:bg-slate-50 hover:text-slate-950'}`}
      >
        首頁
      </a>
      <a 
        href="/products/flawless" 
        class={`block rounded-md px-3 py-2 text-base font-medium ${isFlawless ? 'bg-slate-50 text-slate-950 font-semibold' : 'text-slate-600 hover:bg-slate-50 hover:text-slate-950'}`}
      >
        Flawless 錯題救星
      </a>
      <a 
        href="/products" 
        class={`block rounded-md px-3 py-2 text-base font-medium ${isProducts ? 'bg-slate-50 text-slate-950 font-semibold' : 'text-slate-600 hover:bg-slate-50 hover:text-slate-950'}`}
      >
        精選 App
      </a>
      <a 
        href="/privacy" 
        class={`block rounded-md px-3 py-2 text-base font-medium ${isPrivacy ? 'bg-slate-50 text-slate-950 font-semibold' : 'text-slate-600 hover:bg-slate-50 hover:text-slate-950'}`}
      >
        隱私權政策
      </a>
      <div class="mt-4 px-3">
        <a 
          href="/products" 
          class="flex w-full items-center justify-center rounded-full bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-mint hover:text-slate-900"
        >
          探索產品
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-icon-open');
  const closeIcon = document.getElementById('menu-icon-close');

  if (button && menu && openIcon && closeIcon) {
    button.addEventListener('click', () => {
      const expanded = button.getAttribute('aria-expanded') === 'true';
      button.setAttribute('aria-expanded', String(!expanded));
      
      menu.classList.toggle('hidden');
      openIcon.classList.toggle('hidden');
      closeIcon.classList.toggle('hidden');
    });
  }
</script>
