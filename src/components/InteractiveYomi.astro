---
// InteractiveYomi.astro
---

<div class="w-full max-w-4xl mx-auto bg-slate-900 rounded-3xl p-6 md:p-8 shadow-2xl border border-slate-800">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
    
    <!-- Left panel: Guide & Explanations -->
    <div class="lg:col-span-5 space-y-6 text-slate-300">
      <div>
        <span class="inline-flex items-center gap-1.5 rounded-full bg-brand-yellow/10 px-3 py-1 text-xs font-semibold text-brand-yellow">
          LIVE EXPERIENCE
        </span>
        <h3 class="text-2xl font-bold text-white mt-3">在網頁上，直接體驗 YomiYomi</h3>
        <p class="text-sm mt-3 leading-relaxed text-slate-400">
          透過我們精心設計的動態互動模擬器，您可以直接測試 YomiYomi 兩大領先業界的 AI 閱讀體驗技術。
        </p>
      </div>

      <!-- Features Checklist -->
      <div class="space-y-4 text-sm">
        <div class="flex gap-3">
          <div class="flex-shrink-0 h-5 w-5 rounded-full bg-brand-mint/10 flex items-center justify-center text-brand-mint">
            1
          </div>
          <div>
            <h4 class="font-semibold text-white">語意結構彩色標記</h4>
            <p class="text-xs text-slate-400">主語標記為<span class="text-blue-400 font-medium">藍底</span>，賓語標記為<span class="text-amber-400 font-medium">黃底</span>，助詞標記為<span class="text-slate-500 font-medium">灰色</span>，結構一眼分明。</p>
          </div>
        </div>

        <div class="flex gap-3">
          <div class="flex-shrink-0 h-5 w-5 rounded-full bg-brand-mint/10 flex items-center justify-center text-brand-mint">
            2
          </div>
          <div>
            <h4 class="font-semibold text-white">敬體/常體一鍵切換</h4>
            <p class="text-xs text-slate-400">切換丁寧體（です/ます）與普通形（口語），體驗 AI 如何即時調整整篇文體語意。</p>
          </div>
        </div>

        <div class="flex gap-3">
          <div class="flex-shrink-0 h-5 w-5 rounded-full bg-brand-mint/10 flex items-center justify-center text-brand-mint">
            3
          </div>
          <div>
            <h4 class="font-semibold text-white">智慧假名注音 (Furigana)</h4>
            <p class="text-xs text-slate-400">依設定隱藏低難度假名，例如設定 N3 級別，會自動隱藏「日本(N5)」的注音，避免干擾視覺。</p>
          </div>
        </div>

        <div class="flex gap-3">
          <div class="flex-shrink-0 h-5 w-5 rounded-full bg-brand-mint/10 flex items-center justify-center text-brand-mint">
            4
          </div>
          <div>
            <h4 class="font-semibold text-white">動態文法字典</h4>
            <p class="text-xs text-slate-400">點擊內文中帶有變化的動詞（如「発表させられました」），底部將即時滑出分析與還原步驟。</p>
          </div>
        </div>
      </div>

      <div class="p-3.5 bg-slate-800/50 rounded-xl border border-slate-700/50 text-xs text-slate-400 flex items-start gap-2">
        <span>💡</span>
        <span>提示：右側為模擬 App 操作畫面，請試著點擊新聞內文中的帶底線漢字或切換上方控制項！</span>
      </div>
    </div>

    <!-- Right panel: Smartphone Mockup -->
    <div class="lg:col-span-7 flex justify-center">
      <div class="relative w-full max-w-[340px] aspect-[9/19] rounded-[48px] border-[10px] border-slate-700 bg-yomi-dark shadow-2xl overflow-hidden flex flex-col">
        
        <!-- Phone Camera Notch -->
        <div class="absolute top-2 left-1/2 -translate-x-1/2 w-28 h-4 bg-slate-700 rounded-full z-20 flex items-center justify-center">
          <div class="w-2.5 h-2.5 rounded-full bg-black"></div>
        </div>

        <!-- App Header -->
        <div class="pt-8 pb-3 px-4 bg-slate-900 border-b border-slate-800 text-center relative">
          <div class="text-xs text-slate-500 absolute top-2 left-6">10:42 📱</div>
          <div class="text-xs text-slate-500 absolute top-2 right-6">5G 🔋</div>
          <h4 class="font-bold text-white text-sm tracking-wide">YomiYomi 新聞閱讀器</h4>
        </div>

        <!-- App Control Panel -->
        <div class="p-3 bg-slate-900/60 border-b border-slate-800/80 space-y-2">
          <!-- Tone Selector -->
          <div class="flex justify-between items-center text-xs">
            <span class="text-slate-400">文章文體:</span>
            <div class="flex bg-slate-800 rounded-lg p-0.5 border border-slate-700">
              <button id="btn-polite" class="px-2 py-0.5 rounded-md font-medium bg-brand-mint text-slate-900 transition-all">丁寧 (敬)</button>
              <button id="btn-casual" class="px-2 py-0.5 rounded-md font-medium text-slate-400 transition-all hover:text-white">普通 (常)</button>
            </div>
          </div>

          <!-- Furigana Selector -->
          <div class="flex justify-between items-center text-xs">
            <span class="text-slate-400">智慧注音:</span>
            <div class="flex bg-slate-800 rounded-lg p-0.5 border border-slate-700">
              <button id="furi-all" class="px-1.5 py-0.5 rounded-md bg-slate-700 text-white transition-all">全部</button>
              <button id="furi-n3" class="px-1.5 py-0.5 rounded-md text-slate-400 transition-all hover:text-white">N3級</button>
              <button id="furi-none" class="px-1.5 py-0.5 rounded-md text-slate-400 transition-all hover:text-white">關閉</button>
            </div>
          </div>
        </div>

        <!-- News Content Body -->
        <div class="flex-grow p-4 overflow-y-auto bg-yomi-dark text-slate-200 text-sm">
          <!-- Article Title -->
          <div class="mb-4 pb-3 border-b border-slate-800">
            <span class="inline-block bg-brand-yellow/10 text-brand-yellow px-1.5 py-0.5 rounded text-[10px] font-semibold mb-1">N3 時事</span>
            <h5 class="font-bold text-white text-base leading-snug">
              <ruby class="ruby-tag" data-level="3">新<rt class="rt-tag">あたら</rt></ruby>しい<ruby class="ruby-tag" data-level="2">紙幣<rt class="rt-tag">しへい</rt></ruby>が<ruby class="ruby-tag" data-level="3">発行<rt class="rt-tag">はっこう</rt></ruby>されました
            </h5>
          </div>

          <!-- Article Text (Polite) -->
          <div id="sim-text-polite" class="space-y-4 leading-loose text-[13px] tracking-wide">
            <p>
              <span class="border-b border-blue-500/50 text-blue-300 font-medium px-0.5 cursor-pointer hover:bg-blue-500/10 rounded" data-word-id="1"><ruby class="ruby-tag" data-level="5">日本<rt class="rt-tag">にほん</rt></ruby>政府</span><span class="text-slate-500">は</span><span class="cursor-pointer hover:bg-slate-800 px-0.5 rounded" data-word-id="2"><ruby class="ruby-tag" data-level="5">今日<rt class="rt-tag">きょう</rt></ruby></span>、
              <ruby class="ruby-tag" data-level="5">新<rt class="rt-tag">あたら</rt></ruby>しい
              <span class="border-b border-amber-500/50 text-amber-300 font-medium px-0.5 cursor-pointer hover:bg-amber-500/10 rounded" data-word-id="4"><ruby class="ruby-tag" data-level="5">お札<rt class="rt-tag">おさつ</rt></ruby></span><span class="text-slate-500">を</span>
              <span class="border-b border-amber-500/50 text-amber-300 font-medium px-0.5 cursor-pointer hover:bg-amber-500/10 rounded underline decoration-dashed decoration-brand-mint" data-word-id="5"><ruby class="ruby-tag" data-level="3">発表<rt class="rt-tag">はっぴょう</rt></ruby>させられました</span>。
            </p>
            <p>
              <ruby class="ruby-tag" data-level="5">新<rt class="rt-tag">あたら</rt></ruby>しい
              <span class="border-b border-blue-500/50 text-blue-300 font-medium px-0.5 cursor-pointer hover:bg-blue-500/10 rounded" data-word-id="7"><ruby class="ruby-tag" data-level="2">紙幣<rt class="rt-tag">しへい</rt></ruby></span><span class="text-slate-500">の</span>
              <span class="cursor-pointer hover:bg-slate-800 px-0.5 rounded" data-word-id="8"><ruby class="ruby-tag" data-level="4">顔<rt class="rt-tag">かお</rt></ruby></span><span class="text-slate-500">は</span>、
              <span class="cursor-pointer hover:bg-slate-800 px-0.5 rounded" data-word-id="9"><ruby class="ruby-tag" data-level="3">一万円札<rt class="rt-tag">いちまんえんさつ</rt></ruby></span><span class="text-slate-500">が</span>
              <span class="border-b border-amber-500/50 text-amber-300 font-medium px-0.5 cursor-pointer hover:bg-amber-500/10 rounded" data-word-id="10"><ruby class="ruby-tag" data-level="99">渋沢栄一<rt class="rt-tag">しぶさわえいいち</rt></ruby></span>
              <span class="cursor-pointer hover:bg-slate-800 px-0.5 rounded" data-word-id="11"><ruby class="ruby-tag" data-level="1">氏<rt class="rt-tag">し</rt></ruby></span><span class="cursor-pointer hover:bg-slate-800 px-0.5 rounded" data-word-id="12">です</span>。
            </p>
          </div>

          <!-- Article Text (Casual) - Hidden by default -->
          <div id="sim-text-casual" class="space-y-4 leading-loose text-[13px] tracking-wide hidden">
            <p>
              <span class="border-b border-blue-500/50 text-blue-300 font-medium px-0.5 cursor-pointer hover:bg-blue-500/10 rounded" data-word-id="1"><ruby class="ruby-tag" data-level="5">日本<rt class="rt-tag">にほん</rt></ruby>政府</span><span class="text-slate-500">が</span><span class="cursor-pointer hover:bg-slate-800 px-0.5 rounded" data-word-id="2"><ruby class="ruby-tag" data-level="5">今日<rt class="rt-tag">きょう</rt></ruby></span>、
              <ruby class="ruby-tag" data-level="5">新<rt class="rt-tag">あたら</rt></ruby>しい
              <span class="border-b border-amber-500/50 text-amber-300 font-medium px-0.5 cursor-pointer hover:bg-amber-500/10 rounded" data-word-id="4"><ruby class="ruby-tag" data-level="5">お札<rt class="rt-tag">おさつ</rt></ruby></span><span class="text-slate-500">を</span>
              <span class="border-b border-amber-500/50 text-amber-300 font-medium px-0.5 cursor-pointer hover:bg-amber-500/10 rounded underline decoration-dashed decoration-brand-mint" data-word-id="5-casual"><ruby class="ruby-tag" data-level="3">発表<rt class="rt-tag">はっぴょう</rt></ruby>させられた</span>。
            </p>
            <p>
              <ruby class="ruby-tag" data-level="5">新<rt class="rt-tag">あたら</rt></ruby>しい
              <span class="border-b border-blue-500/50 text-blue-300 font-medium px-0.5 cursor-pointer hover:bg-blue-500/10 rounded" data-word-id="7"><ruby class="ruby-tag" data-level="2">紙幣<rt class="rt-tag">しへい</rt></ruby></span><span class="text-slate-500">の</span>
              <span class="cursor-pointer hover:bg-slate-800 px-0.5 rounded" data-word-id="8"><ruby class="ruby-tag" data-level="4">顔<rt class="rt-tag">かお</rt></ruby></span><span class="text-slate-500">は</span>、
              <span class="cursor-pointer hover:bg-slate-800 px-0.5 rounded" data-word-id="9"><ruby class="ruby-tag" data-level="3">一万円札<rt class="rt-tag">いちまんえんさつ</rt></ruby></span><span class="text-slate-500">が</span>
              <span class="border-b border-amber-500/50 text-amber-300 font-medium px-0.5 cursor-pointer hover:bg-amber-500/10 rounded" data-word-id="10"><ruby class="ruby-tag" data-level="99">渋沢栄一<rt class="rt-tag">しぶさわえいいち</rt></ruby></span>
              <span class="cursor-pointer hover:bg-slate-800 px-0.5 rounded" data-word-id="11"><ruby class="ruby-tag" data-level="1">氏<rt class="rt-tag">し</rt></ruby></span><span class="cursor-pointer hover:bg-slate-800 px-0.5 rounded" data-word-id="12-casual">だ</span>。
            </p>
          </div>
        </div>

        <!-- Pop-up Bottom Sheet (Grammar inflections) -->
        <div id="sim-bottom-sheet" class="bg-slate-900 border-t border-slate-800 p-4 transition-all duration-300 translate-y-full absolute bottom-0 left-0 right-0 z-10 rounded-t-2xl shadow-2xl">
          <div class="flex justify-between items-start mb-2">
            <div>
              <span id="sheet-word" class="font-bold text-white text-base">日本</span>
              <span id="sheet-reading" class="text-slate-400 text-xs ml-2">【にほん】</span>
              <span id="sheet-level" class="inline-block bg-slate-800 text-brand-mint text-[10px] px-1 rounded ml-2">N5</span>
            </div>
            <button id="sheet-close" class="text-slate-400 hover:text-white text-sm p-1">&times;</button>
          </div>
          
          <div class="space-y-2 text-xs">
            <p class="text-slate-300"><strong>詞性：</strong><span id="sheet-pos" class="text-slate-400">名詞</span></p>
            <p class="text-slate-300"><strong>中文翻譯：</strong><span id="sheet-meaning" class="text-brand-yellow font-medium">日本</span></p>
            
            <!-- Grammar inflection path (only visible if verb has inflection) -->
            <div id="sheet-inflection-block" class="hidden bg-slate-800/80 p-2 rounded border border-slate-700/50">
              <p class="text-brand-mint font-semibold mb-1">⚙️ AI 動詞變化還原：</p>
              <p id="sheet-inflection-desc" class="text-slate-300 leading-normal"></p>
            </div>
            
            <div id="sheet-examples-block" class="space-y-1">
              <p class="text-slate-300 font-semibold">📖 例句對照：</p>
              <p id="sheet-example" class="text-slate-400 italic"></p>
            </div>
          </div>
        </div>

      </div>
    </div>

  </div>
</div>

<script>
  // Word data dictionary
  const wordDict: Record<string, any> = {
    "1": {
      word: "日本",
      reading: "にほん",
      level: "N5",
      pos: "名詞",
      meaning: "日本",
      breakdown: null,
      example: "日本に行きたいです。 (我想去日本。)"
    },
    "2": {
      word: "今日",
      reading: "きょう",
      level: "N5",
      pos: "名詞",
      meaning: "今天",
      breakdown: null,
      example: "今日は天気が良いです。 (今天天氣很好。)"
    },
    "4": {
      word: "お札",
      reading: "おさつ",
      level: "N5",
      pos: "名詞",
      meaning: "鈔票、紙鈔",
      breakdown: null,
      example: "お札を財布に入れる。 (把鈔票放進錢包。)"
    },
    "5": {
      word: "発表させられました",
      reading: "はっぴょうさせられました",
      level: "N3",
      pos: "動詞 (使役被動)",
      meaning: "被迫發表/宣布",
      breakdown: "<strong>発表する</strong> (原形/名詞自立) + <strong>させ</strong> (使役助動詞：使/讓) + <strong>られ</strong> (被動助動詞：被) + <strong>ました</strong> (過去丁寧式助動詞：了)",
      example: "みんなの前で発表させられました。 (被迫在所有人面前進行發表。)"
    },
    "5-casual": {
      word: "発表させられた",
      reading: "はっぴょうさせられた",
      level: "N3",
      pos: "動詞 (使役被動 - 常體)",
      meaning: "被迫發表/宣布",
      breakdown: "<strong>発表する</strong> (原形) + <strong>させ</strong> (使役助動詞) + <strong>られ</strong> (被動助動詞) + <strong>た</strong> (過去常體助動詞)",
      example: "みんなの前で発表させられた。 (被迫在所有人面前進行發表。)"
    },
    "7": {
      word: "紙幣",
      reading: "しへい",
      level: "N2",
      pos: "名詞",
      meaning: "紙幣",
      breakdown: null,
      example: "紙幣の歴史を調べる。 (調查紙鈔的歷史。)"
    },
    "8": {
      word: "顔",
      reading: "かお",
      level: "N4",
      pos: "名詞",
      meaning: "臉、肖像人物",
      breakdown: null,
      example: "新しい紙幣の顔。 (新紙鈔的肖像人物。)"
    },
    "9": {
      word: "一万円札",
      reading: "いちまんえんさつ",
      level: "N3",
      pos: "名詞",
      meaning: "一萬元紙鈔",
      breakdown: null,
      example: "一万円札が風で飛んだ。 (一萬元紙鈔被風吹走了。)"
    },
    "10": {
      word: "渋沢栄一",
      reading: "しぶさわえいいち",
      level: "專名",
      pos: "專有名詞",
      meaning: "澀澤榮一 (日本資本主義之父)",
      breakdown: null,
      example: "渋沢栄一は新一万円札の顔だ。 (澀澤榮一是新版一萬元鈔票的肖像人物。)"
    },
    "11": {
      word: "氏",
      reading: "し",
      level: "N1",
      pos: "接尾詞",
      meaning: "先生/女士 (書面尊稱)",
      breakdown: null,
      example: "渋沢氏の功績をたたえる。 (表彰澀澤先生的功績。)"
    },
    "12": {
      word: "です",
      reading: "です",
      level: "N5",
      pos: "助動詞",
      meaning: "是 (敬體判定詞)",
      breakdown: null,
      example: "これは本です。 (這是書。)"
    },
    "12-casual": {
      word: "だ",
      reading: "だ",
      level: "N5",
      pos: "助動詞",
      meaning: "是 (常體判定詞)",
      breakdown: null,
      example: "これは本だ。 (這是書。)"
    }
  };

  // Tone toggling
  const btnPolite = document.getElementById('btn-polite');
  const btnCasual = document.getElementById('btn-casual');
  const simTextPolite = document.getElementById('sim-text-polite');
  const simTextCasual = document.getElementById('sim-text-casual');

  if (btnPolite && btnCasual && simTextPolite && simTextCasual) {
    btnPolite.addEventListener('click', () => {
      // styles
      btnPolite.className = "px-2 py-0.5 rounded-md font-medium bg-brand-mint text-slate-900 transition-all";
      btnCasual.className = "px-2 py-0.5 rounded-md font-medium text-slate-400 transition-all hover:text-white";
      
      // texts
      simTextPolite.classList.remove('hidden');
      simTextCasual.classList.add('hidden');
      closeBottomSheet();
    });

    btnCasual.addEventListener('click', () => {
      // styles
      btnCasual.className = "px-2 py-0.5 rounded-md font-medium bg-brand-mint text-slate-900 transition-all";
      btnPolite.className = "px-2 py-0.5 rounded-md font-medium text-slate-400 transition-all hover:text-white";
      
      // texts
      simTextCasual.classList.remove('hidden');
      simTextPolite.classList.add('hidden');
      closeBottomSheet();
    });
  }

  // Furigana controls
  const btnFuriAll = document.getElementById('furi-all');
  const btnFuriN3 = document.getElementById('furi-n3');
  const btnFuriNone = document.getElementById('furi-none');

  if (btnFuriAll && btnFuriN3 && btnFuriNone) {
    const rubyTags = document.querySelectorAll('.ruby-tag');
    const rtTags = document.querySelectorAll('.rt-tag');

    btnFuriAll.addEventListener('click', () => {
      btnFuriAll.className = "px-1.5 py-0.5 rounded-md bg-slate-700 text-white transition-all";
      btnFuriN3.className = "px-1.5 py-0.5 rounded-md text-slate-400 transition-all hover:text-white";
      btnFuriNone.className = "px-1.5 py-0.5 rounded-md text-slate-400 transition-all hover:text-white";

      rtTags.forEach(rt => {
        (rt as HTMLElement).style.opacity = "1";
        (rt as HTMLElement).style.visibility = "visible";
      });
    });

    btnFuriN3.addEventListener('click', () => {
      btnFuriN3.className = "px-1.5 py-0.5 rounded-md bg-slate-700 text-white transition-all";
      btnFuriAll.className = "px-1.5 py-0.5 rounded-md text-slate-400 transition-all hover:text-white";
      btnFuriNone.className = "px-1.5 py-0.5 rounded-md text-slate-400 transition-all hover:text-white";

      rubyTags.forEach(ruby => {
        const levelAttr = ruby.getAttribute('data-level');
        const rt = ruby.querySelector('.rt-tag') as HTMLElement;
        if (rt) {
          if (levelAttr && (levelAttr === '5' || levelAttr === '4')) {
            // N5, N4 level -> hide for N3 user (already mastered)
            rt.style.opacity = "0";
            rt.style.visibility = "hidden";
          } else {
            rt.style.opacity = "1";
            rt.style.visibility = "visible";
          }
        }
      });
    });

    btnFuriNone.addEventListener('click', () => {
      btnFuriNone.className = "px-1.5 py-0.5 rounded-md bg-slate-700 text-white transition-all";
      btnFuriAll.className = "px-1.5 py-0.5 rounded-md text-slate-400 transition-all hover:text-white";
      btnFuriN3.className = "px-1.5 py-0.5 rounded-md text-slate-400 transition-all hover:text-white";

      rtTags.forEach(rt => {
        (rt as HTMLElement).style.opacity = "0";
        (rt as HTMLElement).style.visibility = "hidden";
      });
    });
  }

  // Interactive Clickable Words & Bottom Sheet
  const clickableWords = document.querySelectorAll('[data-word-id]');
  const bottomSheet = document.getElementById('sim-bottom-sheet');
  const sheetWord = document.getElementById('sheet-word');
  const sheetReading = document.getElementById('sheet-reading');
  const sheetLevel = document.getElementById('sheet-level');
  const sheetPos = document.getElementById('sheet-pos');
  const sheetMeaning = document.getElementById('sheet-meaning');
  const sheetInflectionBlock = document.getElementById('sheet-inflection-block');
  const sheetInflectionDesc = document.getElementById('sheet-inflection-desc');
  const sheetExample = document.getElementById('sheet-example');
  const sheetClose = document.getElementById('sheet-close');

  function openBottomSheet(wordId: string) {
    const data = wordDict[wordId];
    if (!data || !bottomSheet || !sheetWord || !sheetReading || !sheetLevel || !sheetPos || !sheetMeaning || !sheetInflectionBlock || !sheetInflectionDesc || !sheetExample) return;

    sheetWord.textContent = data.word;
    sheetReading.textContent = `【${data.reading}】`;
    sheetLevel.textContent = data.level;
    sheetPos.textContent = data.pos;
    sheetMeaning.textContent = data.meaning;

    if (data.breakdown) {
      sheetInflectionBlock.classList.remove('hidden');
      sheetInflectionDesc.innerHTML = data.breakdown;
    } else {
      sheetInflectionBlock.classList.add('hidden');
    }

    if (data.example) {
      sheetExample.textContent = data.example;
    } else {
      sheetExample.textContent = "暫無例句。";
    }

    bottomSheet.classList.remove('translate-y-full');
  }

  function closeBottomSheet() {
    if (bottomSheet) {
      bottomSheet.classList.add('translate-y-full');
    }
  }

  clickableWords.forEach(word => {
    word.addEventListener('click', (e) => {
      e.stopPropagation();
      const wordId = (word as HTMLElement).getAttribute('data-word-id');
      if (wordId) {
        openBottomSheet(wordId);
      }
    });
  });

  if (sheetClose) {
    sheetClose.addEventListener('click', (e) => {
      e.stopPropagation();
      closeBottomSheet();
    });
  }

  // Click outside to close bottom sheet
  document.addEventListener('click', () => {
    closeBottomSheet();
  });

  if (bottomSheet) {
    bottomSheet.addEventListener('click', (e) => {
      e.stopPropagation(); // prevent closing when clicking inside sheet
    });
  }
</script>
